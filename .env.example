# ============================================================
# Matrix Homeserver Stack — Environment Configuration
# ============================================================
# 1. Copy:  cp .env.example .env
# 2. Edit:  Fill in domains, email, and passwords
# 3. Secrets: Run  scripts/generate-secrets.sh  (fills SYNAPSE_* secrets)
# ============================================================

# ------------------------------------------------------------
# MATRIX IDENTITY  ⚠  Cannot be changed after first run
# ------------------------------------------------------------
# MATRIX_SERVER_NAME: Your Matrix identity domain.
# This appears in all Matrix IDs: @alice:example.com
# It does NOT have to be the same as SYNAPSE_HOSTNAME.
MATRIX_SERVER_NAME=example.com

# SYNAPSE_HOSTNAME: The hostname where Synapse is reachable.
# Traefik will route HTTPS traffic here.
SYNAPSE_HOSTNAME=matrix.example.com

# ELEMENT_HOSTNAME: The hostname where Element Web is served.
ELEMENT_HOSTNAME=chat.example.com

# SYNAPSE_ADMIN_HOSTNAME: The hostname where Synapse Admin is served.
SYNAPSE_ADMIN_HOSTNAME=admin.example.com

# SYNAPSE_PUBLIC_BASEURL: Full URL of your Synapse instance.
# Must start with https://. No trailing slash.
SYNAPSE_PUBLIC_BASEURL=https://matrix.example.com

# ------------------------------------------------------------
# TRAEFIK / TLS
# ------------------------------------------------------------
# Email address for Let's Encrypt certificate notifications.
TRAEFIK_ACME_EMAIL=admin@example.com

# Dashboard: disabled in production; enable only temporarily for debugging.
TRAEFIK_DASHBOARD_ENABLED=false

# If dashboard enabled, set the hostname where it will be served.
TRAEFIK_DASHBOARD_HOSTNAME=traefik.example.com

# BasicAuth credentials for the dashboard.
# Generate with: htpasswd -nb admin yourpassword
# Dollar signs must be doubled in .env: $$ instead of $
# Example: admin:$$2y$$05$$...hashhere...
TRAEFIK_DASHBOARD_BASICAUTH=

# BasicAuth credentials for Synapse Admin.
# Generate with: htpasswd -nb admin yourpassword
# Dollar signs must be doubled in .env: $$ instead of $
# Example: admin:$$2y$$05$$...hashhere...
SYNAPSE_ADMIN_BASICAUTH=

# ------------------------------------------------------------
# POSTGRESQL
# ------------------------------------------------------------
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_redis_password

# ------------------------------------------------------------
# SYNAPSE SECRETS  — run scripts/generate-secrets.sh to fill these
# ------------------------------------------------------------
# Macaroon secret: used to generate access tokens
SYNAPSE_MACAROON_SECRET_KEY=

# Form secret: used for CSRF protection
SYNAPSE_FORM_SECRET=

# Registration shared secret: used to create admin users without open registration
SYNAPSE_REGISTRATION_SHARED_SECRET=

# ------------------------------------------------------------
# COTURN / TURN SERVER
# ------------------------------------------------------------
# COTURN_REALM: The realm for the TURN server. Usually your base domain.
COTURN_REALM=example.com

# COTURN_STATIC_AUTH_SECRET: Shared secret between Synapse and Coturn.
# Should be a long random string. Generate with: openssl rand -base64 32
COTURN_STATIC_AUTH_SECRET=CHANGE_ME_coturn_secret

# UDP port range for TURN media relay.
COTURN_MIN_PORT=49152
COTURN_MAX_PORT=65535

# COTURN_EXTERNAL_IP: Your server's public IPv4 address.
# Set to 'detect' to auto-detect (works on most VPS providers via ifconfig.me).
# Or set explicitly: COTURN_EXTERNAL_IP=203.0.113.42
COTURN_EXTERNAL_IP=detect

# TURN/STUN listening ports.
COTURN_PORT=3478
COTURN_TLS_PORT=5349

# ------------------------------------------------------------
# EMAIL  (disabled by default)
# ------------------------------------------------------------
# Set MATRIX_EMAIL_ENABLED=true and fill in SMTP details to enable email
# notifications, password reset, and email verification.
MATRIX_EMAIL_ENABLED=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Sender address for system emails.
EMAIL_FROM=Matrix <matrix@example.com>
EMAIL_NOTIF_FROM=Matrix <matrix@example.com>

# ------------------------------------------------------------
# SYNAPSE TUNING
# ------------------------------------------------------------
# Enable public registration. Set to true only for public servers.
# WARNING: Enabling registration without captcha will attract spammers.
SYNAPSE_ENABLE_REGISTRATION=false

# Allow guest access (anonymous read-only access to public rooms).
SYNAPSE_ALLOW_GUEST_ACCESS=false

# Enable Matrix federation (communication with other homeservers).
# Disable for a private, isolated homeserver.
SYNAPSE_FEDERATION_ENABLED=true

# Maximum file upload size for media (e.g. 50M, 100M, 1G).
SYNAPSE_MAX_UPLOAD_SIZE=50M
