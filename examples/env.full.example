# ============================================================
# Matrix Homeserver Stack — Full Environment Configuration
# ============================================================
# This file documents ALL available configuration options.
# For a minimal setup, see examples/env.minimal.example
#
# Usage:
#   cp examples/env.full.example .env
#   # Edit with your actual values
#   bash scripts/generate-secrets.sh
#   bash bootstrap.sh
# ============================================================

# ------------------------------------------------------------
# MATRIX IDENTITY  ⚠  Cannot be changed after first run
# ------------------------------------------------------------
# This is the domain that appears in all Matrix IDs.
# @alice:example.com  — server_name is 'example.com'
# Choose this carefully. It cannot be changed.
MATRIX_SERVER_NAME=example.com

# The hostname where Synapse is actually reachable.
# Can be different from MATRIX_SERVER_NAME (well-known delegation handles it).
SYNAPSE_HOSTNAME=matrix.example.com

# The hostname where Element Web client is served.
ELEMENT_HOSTNAME=chat.example.com

# Full public base URL. Must start with https://. No trailing slash.
SYNAPSE_PUBLIC_BASEURL=https://matrix.example.com

# ------------------------------------------------------------
# TRAEFIK / TLS
# ------------------------------------------------------------
TRAEFIK_ACME_EMAIL=admin@example.com

# Enable Traefik dashboard (not recommended in production)
TRAEFIK_DASHBOARD_ENABLED=false

# Hostname for Traefik dashboard (only used if TRAEFIK_DASHBOARD_ENABLED=true)
TRAEFIK_DASHBOARD_HOSTNAME=traefik.example.com

# BasicAuth for dashboard: htpasswd -nb admin yourpassword
# Dollar signs must be doubled: $$ instead of $
# Example: admin:$$2y$$05$$UKvwHjsEKEBZdZ9fGvGYLeqLXm8YCSwDlv2D4xMz3v8oMKilXXpnS
TRAEFIK_DASHBOARD_BASICAUTH=

# ------------------------------------------------------------
# POSTGRESQL
# ------------------------------------------------------------
POSTGRES_DB=synapse
POSTGRES_USER=synapse
# Use a strong random password (min 20 chars)
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_at_least_20_chars

# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
# Redis is used for Synapse worker coordination and caching.
# Password is passed via command line (not stored in redis.conf).
REDIS_PASSWORD=CHANGE_ME_redis_password_at_least_20_chars

# ------------------------------------------------------------
# SYNAPSE SECRETS  — run: bash scripts/generate-secrets.sh
# ------------------------------------------------------------
# Macaroon secret: used to sign access tokens.
# Changing this invalidates all existing sessions (logs out all users).
SYNAPSE_MACAROON_SECRET_KEY=

# Form secret: used for CSRF protection on forms.
SYNAPSE_FORM_SECRET=

# Registration shared secret: used by create-admin-user.sh to create
# admin accounts without requiring open registration.
SYNAPSE_REGISTRATION_SHARED_SECRET=

# ------------------------------------------------------------
# COTURN / TURN SERVER
# ------------------------------------------------------------
# The realm used in TURN authentication.
COTURN_REALM=example.com

# Shared secret between Synapse and Coturn.
# Must be a long random string (min 32 chars).
COTURN_STATIC_AUTH_SECRET=CHANGE_ME_coturn_secret_at_least_32_chars

# UDP port range for TURN media relay.
# These ports must be open in your firewall.
COTURN_MIN_PORT=49152
COTURN_MAX_PORT=65535

# Your server's public IPv4 address.
# Set to 'detect' for auto-detection from ifconfig.me.
# Or set explicitly: COTURN_EXTERNAL_IP=203.0.113.42
COTURN_EXTERNAL_IP=detect

# TURN listening ports.
COTURN_PORT=3478
COTURN_TLS_PORT=5349

# ------------------------------------------------------------
# EMAIL  (disabled by default)
# ------------------------------------------------------------
# Set to 'true' and fill in SMTP details to enable:
#   - Email verification for registration
#   - Password reset via email
#   - Push notification emails
MATRIX_EMAIL_ENABLED=false

# SMTP server hostname
SMTP_HOST=smtp.example.com

# SMTP port (587 for STARTTLS, 465 for SSL/TLS, 25 for unencrypted)
SMTP_PORT=587

# SMTP authentication
SMTP_USER=matrix@example.com
SMTP_PASSWORD=your-smtp-password

# Sender address for system emails
EMAIL_FROM=Matrix <matrix@example.com>

# Sender address for notification emails
EMAIL_NOTIF_FROM=Matrix <matrix@example.com>

# ------------------------------------------------------------
# SYNAPSE FEATURE FLAGS
# ------------------------------------------------------------
# Enable public user registration.
# Set to 'true' only if you want anyone to be able to create accounts.
# WARNING: Without CAPTCHA, spammers will abuse open registration.
SYNAPSE_ENABLE_REGISTRATION=false

# Allow guest/anonymous access (read-only public rooms without an account).
SYNAPSE_ALLOW_GUEST_ACCESS=false

# Enable federation with other Matrix homeservers.
# Set to 'false' for a completely private, isolated homeserver.
SYNAPSE_FEDERATION_ENABLED=true

# Maximum file upload size.
# Supports M (megabytes) and G (gigabytes) suffixes.
# Default 50M is conservative; increase for media-heavy deployments.
SYNAPSE_MAX_UPLOAD_SIZE=50M

# ------------------------------------------------------------
# BACKUP CONFIGURATION (used by scripts/backup.sh)
# ------------------------------------------------------------
# Include .env in backup (contains sensitive secrets — be careful)
BACKUP_ENV=false

# Delete backups older than this many days (0 = keep forever)
BACKUP_RETENTION_DAYS=30
