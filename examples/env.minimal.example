# ============================================================
# Matrix Homeserver — Minimal Environment Configuration
# ============================================================
# These are the minimum required variables to get started.
# For a full list of options, see .env.example
#
# Usage:
#   cp examples/env.minimal.example .env
#   # Edit with your values:
#   nano .env
#   # Generate secrets:
#   bash scripts/generate-secrets.sh
# ============================================================

# Your Matrix identity domain (appears in user IDs: @alice:example.com)
# WARNING: Cannot be changed after first run!
MATRIX_SERVER_NAME=example.com

# Hostname where Synapse (the homeserver) runs
SYNAPSE_HOSTNAME=matrix.example.com

# Hostname where Element (the web client) runs
ELEMENT_HOSTNAME=chat.example.com

# Full public URL of Synapse (must match SYNAPSE_HOSTNAME)
SYNAPSE_PUBLIC_BASEURL=https://matrix.example.com

# Email for Let's Encrypt TLS certificate notifications
TRAEFIK_ACME_EMAIL=admin@example.com

# Strong database password (min 20 chars recommended)
POSTGRES_PASSWORD=your_db_password_here

# Strong Redis password (min 20 chars recommended)
REDIS_PASSWORD=your_redis_password_here

# TURN server shared secret (min 32 chars recommended)
COTURN_STATIC_AUTH_SECRET=your_coturn_secret_here

# Synapse secrets — leave empty and run: bash scripts/generate-secrets.sh
SYNAPSE_MACAROON_SECRET_KEY=
SYNAPSE_FORM_SECRET=
SYNAPSE_REGISTRATION_SHARED_SECRET=
