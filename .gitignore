# ============================================================
# Matrix Homeserver Stack — .gitignore
# ============================================================

# ------------------------------------------------------------
# Environment secrets — NEVER commit .env
# ------------------------------------------------------------
.env
# .env.example is committed (it's a template with no real secrets)
!.env.example

# ------------------------------------------------------------
# Runtime data directories — generated at bootstrap time
# Keep .gitkeep files to preserve directory structure in git
# ------------------------------------------------------------
data/*
!data/.gitkeep

data/synapse/*
!data/synapse/.gitkeep

data/coturn/*
!data/coturn/.gitkeep

data/well-known/*
!data/well-known/.gitkeep

# Signing keys (extremely sensitive — loss of key = loss of server identity)
*.signing.key

# ------------------------------------------------------------
# Backup directory — potentially large, always exclude
# Keep .gitkeep to preserve the directory in git
# ------------------------------------------------------------
backups/*
!backups/.gitkeep

# ------------------------------------------------------------
# Traefik ACME data (if ever bind-mounted instead of named volume)
# ------------------------------------------------------------
acme.json
config/traefik/acme/

# ------------------------------------------------------------
# Log files
# ------------------------------------------------------------
*.log
logs/
*.log.*

# ------------------------------------------------------------
# Editor and IDE files
# ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.fleet/

# ------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig

# ------------------------------------------------------------
# Python (if any tooling scripts use it)
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# Node.js (if any web tooling is added)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.pid
*.seed
*.pid.lock
coverage/
.nyc_output/
